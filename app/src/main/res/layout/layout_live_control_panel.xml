<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_live_bg_bottom"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- 操作按钮行（居中） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/control_rewind_10"
            android:layout_width="70dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="-10s"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/control_play_pause"
            android:layout_width="80dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="暂停"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:background="#44FFFFFF"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/control_forward_10"
            android:layout_width="70dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="+10s"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:background="#33FFFFFF" />
    </LinearLayout>

    <!-- 信息行：节目名（左） + 当前时间/总时间（右） -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/control_program_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:text="节目名称"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:paddingLeft="4dp"
                android:paddingRight="4dp" />

            <TextView
                android:id="@+id/control_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="直播"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- 进度条行（复用点播进度条样式） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:layout_marginBottom="8dp">

        <SeekBar
            android:id="@+id/control_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressDrawable="@drawable/shape_player_control_vod_seek"
            android:thumb="@drawable/shape_player_control_vod_seek_thumb"
            android:max="100" />
    </LinearLayout>

    <!-- 底部行：日期/节目信息（左） + 倍速按钮（右） -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <LinearLayout
            android:id="@+id/control_info_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/control_date_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04月10日 周四"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/control_current_epg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在播放：新闻联播 19:00-19:30"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/control_speed_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center"
            android:text="倍速 1.0x"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:background="#33FFFFFF" />
    </RelativeLayout>

</LinearLayout>
